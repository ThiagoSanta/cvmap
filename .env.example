# Servidor
PORT=3000
NODE_ENV=development

# Base de datos
DB_PATH=./database/cvmap.sqlite

# Nominatim API (Geocoding)
NOMINATIM_API_URL=https://nominatim.openstreetmap.org/search

# Overpass API
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_API_URL_FALLBACK=https://overpass.kumi.systems/api/interpreter
OVERPASS_API_URL_FALLBACK_2=https://overpass.nchc.org.tw/api/interpreter
# Timeout del cliente HTTP para Overpass en milisegundos (por defecto: 60000 = 60s).
# Aumentar si se consultan ciudades muy grandes con radios amplios (>10km).
OVERPASS_TIMEOUT_MS=60000

# Caché de resultados de empresas (en días)
CACHE_EXPIRATION_DAYS=30

# Radio de búsqueda por defecto (en metros)
DEFAULT_SEARCH_RADIUS=15000